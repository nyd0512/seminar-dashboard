{
  "hosting": [
    {
      "target": "default",
      "public": ".",
      "predeploy": [
        "node scripts/build-materials-manifest.mjs"
      ],
      "ignore": [
        "firebase.json",
        ".firebaserc",
        ".firebase/**",
        "**/.*",
        "**/node_modules/**",
        "README.md",
        "HANDOFF.md",
        "firestore.rules",
        "firestore.indexes.json",
        "*-firebase-adminsdk-*.json",
        "serviceAccountKey*.json"
      ],
      "cleanUrls": true,
      "headers": [
        {
          "source": "**/*.@(jpg|jpeg|png|webp|svg|woff2)",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
          ]
        },
        {
          "source": "**/*.@(css|js)",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" }
          ]
        },
        {
          "source": "**/*.html",
          "headers": [
            { "key": "Cache-Control", "value": "no-store" }
          ]
        }
      ]
    },
    {
